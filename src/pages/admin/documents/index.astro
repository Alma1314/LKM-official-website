---
import PageLayout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '文档管理 — LKM',
  description: 'LKM 管理后台 — 文档列表',
};
---

<PageLayout metadata={metadata}>
  <div class="section-container max-w-4xl mx-auto py-8 px-4">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold">文档管理</h1>
      <a href="/admin/documents/editor" class="btn btn-primary">新建文档</a>
    </div>
    <div id="doc-list" class="bg-base-100 border border-base-300 rounded-lg overflow-hidden">
      <div class="p-8 text-center text-base-content/50">
        <span class="loading loading-spinner loading-md"></span>
        <p class="mt-2 text-sm">正在加载文档列表……</p>
      </div>
    </div>
  </div>
</PageLayout>

<script>
  import { listDocuments } from '~/lib/document-api';

  function renderList() {
    const docs = listDocuments();
    const container = document.getElementById('doc-list');
    if (!container) return;

    if (docs.length === 0) {
      container.innerHTML = `
        <div class="p-12 text-center text-base-content/50">
          <p class="text-lg">暂无文档</p>
          <p class="text-sm mt-1">点击"新建文档"开始编写</p>
        </div>
      `;
      return;
    }

    container.innerHTML = docs
      .map(
        (doc) => `
      <a href="/admin/documents/editor?id=${doc.id}" class="flex items-center justify-between p-4 border-b border-base-300 last:border-b-0 hover:bg-base-200 transition-colors">
        <div>
          <h3 class="font-medium">${escapeHtml(doc.title)}</h3>
          <p class="text-xs text-base-content/50 mt-1">
            ${new Date(doc.lastModified).toLocaleString('zh-CN')} ·
            <span class="badge badge-xs ${doc.status === 'published' ? 'badge-success' : 'badge-ghost'}">${doc.status === 'published' ? '已发布' : doc.status === 'archived' ? '已归档' : '草稿'}</span>
          </p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-base-content/30">
          <path d="m9 18 6-6-6-6"/>
        </svg>
      </a>
    `
      )
      .join('');
  }

  function escapeHtml(text: string) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  renderList();
</script>
