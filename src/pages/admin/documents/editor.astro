---
import PageLayout from '~/layouts/PageLayout.astro';

const metadata = {
  title: '编辑文档 — LKM',
  description: 'LKM 管理后台 — 文档编辑',
};
---

<PageLayout metadata={metadata}>
  <div class="section-container max-w-4xl mx-auto py-8 px-4">
    <div class="mb-4 flex items-center gap-3">
      <a href="/admin/documents" class="btn btn-ghost btn-sm gap-1">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        返回列表
      </a>
    </div>
    <div id="editor-mount">
      <div class="flex items-center justify-center min-h-[60vh] border border-base-300 rounded-lg bg-base-100">
        <span class="loading loading-spinner loading-md mr-2"></span>
        <span class="text-base-content/50">正在加载编辑器……</span>
      </div>
    </div>
  </div>
</PageLayout>

<script>
  function getDocumentId() {
    const params = new URLSearchParams(window.location.search);
    const id = params.get('id');
    if (id) return id;
    const hash = window.location.hash.slice(1);
    if (hash) return hash;
    return 'new';
  }

  const mount = document.getElementById('editor-mount');
  if (mount) {
    // Show spinner with progress indicator while editor loads asynchronously
    const spinner = document.createElement('div');
    spinner.className =
      'flex flex-col items-center justify-center min-h-[60vh] border border-base-300 rounded-lg bg-base-100 gap-3';
    spinner.innerHTML = `<span class="loading loading-spinner loading-lg text-primary"></span>
      <span class="text-base-content/50 text-sm" id="editor-loading-text">正在加载编辑器</span>`;

    // Animated progress dots
    let dots = 0;
    const progressTimer = setInterval(() => {
      dots = (dots + 1) % 4;
      const el = document.getElementById('editor-loading-text');
      if (el) el.textContent = '\u6b63\u5728\u52a0\u8f7d\u7f16\u8f91\u5668' + '.'.repeat(dots);
    }, 500);

    Promise.all([import('react'), import('react-dom/client'), import('~/components/editor/DocumentEditor')])
      .then(([React, ReactDOM, DocEditor]) => {
        clearInterval(progressTimer);
        const root = ReactDOM.createRoot(mount);
        root.render(React.createElement(DocEditor.default, { documentId: getDocumentId() }));
      })
      .catch(() => {
        clearInterval(progressTimer);
        mount.innerHTML = `<div class="flex items-center justify-center min-h-[60vh] border border-base-300 rounded-lg bg-base-100">
          <span class="text-error">编辑器加载失败，请刷新页面重试</span></div>`;
      });
  }
</script>
