---
interface Props {
  type?: 'info' | 'warning' | 'error' | 'success';
  title?: string;
}

const { type = 'info', title } = Astro.props as Props;

const alertClass = {
  info: 'alert-info',
  warning: 'alert-warning',
  error: 'alert-error',
  success: 'alert-success',
}[type];

const icons: Record<string, string> = {
  info: 'ℹ️',
  warning: '⚠️',
  error: '❌',
  success: '✅',
};
---

<div class:list={['alert', alertClass, 'my-4 not-prose']}>
  <span class="text-lg">{icons[type]}</span>
  <div>
    {title && <h4 class="font-semibold text-sm">{title}</h4>}
    <div class="text-sm">
      <slot />
    </div>
  </div>
</div>
